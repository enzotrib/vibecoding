---
import Icon from './Icon.astro';
import heroImage from '../assets/hero-image.webp';

const stats = [
  { icon: 'sparkle', title: 'AI-Native Workflow', text: 'Prototipado ultrarrápido', tone: 'orange' },
  { icon: 'cube', title: 'Product Mindset', text: 'Enfoque en negocio real', tone: 'blue' },
  { icon: 'bolt', title: 'Full-Stack Speed', text: 'Días, no meses', tone: 'violet' },
];
---

<section class="hero" id="home">
  <div class="hero-content">
    <div class="eyebrow"><span class="bolt-mini">◆</span> AI-powered developer</div>
    <h1>I build <span class="gradient-text">AI-powered</span> products fast.</h1>
    <p class="hero-copy">VibeCoding, automation and full-stack development to turn ideas into working products in days, not months.</p>
    <div class="actions">
      <a class="btn btn-primary" href="#builds">View my work</a>
      <a class="btn btn-secondary" href="#contact">Get in touch <span aria-hidden="true">→</span></a>
    </div>
    <div class="hero-stats" aria-label="Builder advantages">
      {stats.map((stat) => (
        <div class="stat">
          <div class:list={['stat-icon-box', stat.tone]}>
            <Icon name={stat.icon} />
          </div>
          <span><strong>{stat.title}</strong>{stat.text}</span>
        </div>
      ))}
    </div>
  </div>
  <div class="hero-image-wrap">
    <img src={heroImage.src} alt="AI Product Builder" class="hero-img" />
  </div>
</section>
