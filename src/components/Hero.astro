---
import Icon from './Icon.astro';
import heroImage from '../assets/hero-image.webp';
import { ui } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].hero;

const stats = [
  { icon: 'sparkle', title: t.stat1Title, text: t.stat1Text, tone: 'orange' },
  { icon: 'cube', title: t.stat2Title, text: t.stat2Text, tone: 'blue' },
  { icon: 'bolt', title: t.stat3Title, text: t.stat3Text, tone: 'violet' },
];
---

<section class="hero" id="home">
  <div class="hero-content">
    <div class="eyebrow"><span class="bolt-mini">◆</span> {t.eyebrow}</div>
    <h1>{t.titleStart} <span class="gradient-text">{t.titleAccent}</span> {t.titleEnd}</h1>
    <p class="hero-copy">{t.copy}</p>
    <div class="actions">
      <a class="btn btn-primary" href="#builds">{t.ctaPrimary}</a>
      <a class="btn btn-secondary" href="#contact">{t.ctaSecondary} <span aria-hidden="true">→</span></a>
    </div>
    <div class="hero-stats" aria-label="Builder advantages">
      {stats.map((stat) => (
        <div class="stat">
          <div class:list={['stat-icon-box', stat.tone]}>
            <Icon name={stat.icon} />
          </div>
          <span><strong>{stat.title}</strong>{stat.text}</span>
        </div>
      ))}
    </div>
  </div>
  <div class="hero-image-wrap">
    <img src={heroImage.src} alt="AI Product Builder" class="hero-img" />
  </div>
</section>
