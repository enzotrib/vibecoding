---
import BrandMark from './BrandMark.astro';
import Icon from './Icon.astro';
---

<footer class="footer page">
  <div>
    <a class="brand" href="#" aria-label="VibeCoding home">
      <BrandMark />
      <span>VibeCoding</span>
    </a>
    <p>AI-powered development.<br />Less. Scalable. Reliable.</p>
  </div>
  
  <div>
    <h3>Contact</h3>
    <ul class="contact-list">
      <li>
        <a href="mailto:enzotrib@gmail.com">
          <Icon name="lucide:mail" class="mini-icon" />
          enzotrib@gmail.com
        </a>
      </li>
      <li>
        <a href="https://wa.me/543465430303" target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:message-circle" class="mini-icon" />
          WhatsApp
        </a>
      </li>
    </ul>
  </div>

  <div>
    <h3>Redes</h3>
    <ul class="contact-list">
      <li>
        <a href="https://www.linkedin.com/in/enzo-tribiani/" target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:linkedin" class="mini-icon" />
          LinkedIn
        </a>
      </li>
      <li>
        <a href="https://www.tiktok.com/@evibecode" target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:tiktok" class="mini-icon" />
          TikTok
        </a>
      </li>
      <li>
        <a href="https://github.com/enzotrib" target="_blank" rel="noopener noreferrer">
          <Icon name="simple-icons:github" class="mini-icon" />
          GitHub
        </a>
      </li>
    </ul>
  </div>
  
  <div class="copyright">© 2026 VibeCoding. All rights reserved.</div>
</footer>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .contact-list li a {
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s ease;
    color: #b4bed1;
    font-size: 13px;
  }
  .contact-list li a:hover {
    color: #fff;
  }
  .mini-icon {
    width: 18px;
    height: 18px;
    opacity: 0.7;
  }
  .footer {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: 60px;
    padding: 80px 40px 48px;
  }
  .copyright {
    grid-column: 1 / -1;
    margin: 40px 0 0;
    text-align: center;
    color: #8791a8;
    font-size: 12px;
  }
</style>
