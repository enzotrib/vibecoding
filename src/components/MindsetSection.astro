---
import Icon from './Icon.astro';

const roles = [
  ['sparkle', 'violet', 'AI Product Builder'],
  ['bolt', 'orange', 'VibeCoding Developer'],
  ['target', 'blue', 'Rapid Prototyping Engineer'],
];
---

<section class="mindset" id="about">
  <div>
    <h2>Builder mindset</h2>
    <p>I’m a developer focused on building real products, not just writing code. Over the past years, I’ve evolved from traditional web development into AI-powered product building (VibeCoding), combining speed, automation, and modern tooling.</p>
  </div>
  <div class="mindset-grid">
    {roles.map(([icon, color, label]) => (
      <div class="mindset-pill"><span class:list={['mini-icon', color]}><Icon name={icon} class="" /></span>{label}</div>
    ))}
  </div>
</section>
