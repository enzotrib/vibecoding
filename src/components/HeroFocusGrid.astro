---
const tileCount = 144;
const logos: Record<number, { name: string; label: string; tone: string }> = {
  18: { name: 'wind', label: 'Windsurf', tone: 'violet' },
  31: { name: 'openai', label: 'OpenAI', tone: 'white' },
  33: { name: 'vercel', label: 'Vercel', tone: 'white' },
  44: { name: 'supabase', label: 'Supabase', tone: 'green' },
  55: { name: 'github', label: 'GitHub', tone: 'white' },
  58: { name: 'node', label: 'Node.js', tone: 'green' },
  70: { name: 'js', label: 'JavaScript', tone: 'yellow' },
  82: { name: 'tailwind', label: 'Tailwind', tone: 'cyan' },
  97: { name: 'wind', label: 'Windsurf', tone: 'violet' },
  100: { name: 'openai', label: 'OpenAI', tone: 'white' },
  110: { name: 'supabase', label: 'Supabase', tone: 'green' },
  113: { name: 'github', label: 'GitHub', tone: 'white' },
  121: { name: 'tailwind', label: 'Tailwind', tone: 'cyan' },
};

const hotTiles = new Set([18, 29, 30, 31, 33, 42, 43, 44, 55, 56, 58, 69, 70, 82, 83, 97, 100, 109, 110, 113, 121]);
---

<aside class="hero-focus" data-hero-focus aria-label="VibeCoding tools background grid">
  <div class="hero-focus-grid-track">
    {Array.from({ length: tileCount }).map((_, index) => {
      const logo = logos[index];
      return (
        <span class:list={['bg-square', 'focus-square', hotTiles.has(index) && 'is-hot', logo && 'has-logo']}>
          {logo && (
            <span class:list={['tool-logo', logo.tone]} aria-label={logo.label}>
              {logo.name === 'wind' && <svg viewBox="0 0 24 24"><path d="m12 3 8 6v9l-8 3-8-3V9z"></path><path d="M12 3v18M4 9l8 4 8-4"></path></svg>}
              {logo.name === 'openai' && <svg viewBox="0 0 72 72"><path d="M28 16c8-8 24-3 26 8 10 3 12 18 3 24 2 11-11 20-20 14-9 6-22-2-20-14-9-6-7-21 3-24 1-4 4-7 8-8z"></path><path d="M24 26 45 38M48 26 27 39M25 48V25l20-11M47 24v24L27 59"></path></svg>}
              {logo.name === 'vercel' && <svg viewBox="0 0 24 24"><path d="m12 3 9 18H3z" fill="currentColor" stroke="none"></path></svg>}
              {logo.name === 'supabase' && <svg viewBox="0 0 24 24"><path d="m13 2-9 13h8l-1 7 9-13h-8z"></path></svg>}
              {logo.name === 'github' && <svg viewBox="0 0 24 24"><path d="M9 19c-5 1-5-3-7-4M15 22v-4c0-1 .3-1.8 1-2.5 3-.3 6-1.5 6-7A5.5 5.5 0 0 0 20 4c.2-1.5-.2-2.5-.8-3 0 0-1.4 0-3 1.2A10 10 0 0 0 12 2a10 10 0 0 0-4.2.2C6.2 1 4.8 1 4.8 1 4.2 1.5 3.8 2.5 4 4a5.5 5.5 0 0 0-2 4.5c0 5.5 3 6.7 6 7 .7.7 1 1.5 1 2.5v4"></path></svg>}
              {logo.name === 'node' && <svg viewBox="0 0 24 24"><path d="m12 3 8 4v10l-8 4-8-4V7z"></path><path d="M9 12h6M12 9v6"></path></svg>}
              {logo.name === 'js' && <svg viewBox="0 0 24 24"><path d="M5 5h14v14H5z"></path><path d="M9 15c0 2 3 2 3 0V9M15 15c1 2 4 1 4-1 0-2-4-1-4-3 0-2 3-2 4-1"></path></svg>}
              {logo.name === 'tailwind' && <svg viewBox="0 0 24 24"><path d="M3 12c3-5 6-5 9 0 3 5 6 5 9 0"></path><path d="M3 17c3-5 6-5 9 0 3 5 6 5 9 0"></path></svg>}
            </span>
          )}
        </span>
      );
    })}
  </div>
  <p class="hero-panel-copy">I connect tools, automate workflows and ship products that deliver real impact.</p>
</aside>
