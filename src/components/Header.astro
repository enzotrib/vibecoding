---
import BrandMark from './BrandMark.astro';
import LangSwitch from './LangSwitch.astro';
import { ui } from '../i18n/ui';
import { getLangFromUrl, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];

const links = [
  { label: t.nav.projects, href: '#builds' },
  { label: t.nav.stack, href: '#stack' },
  { label: t.nav.process, href: '#process' },
  { label: t.nav.about, href: '#about' },
];
---

<header class="header page">
  <nav class="nav" aria-label={t.nav.ariaLabel}>
    <a class="brand" href={getLocalizedPath(lang)} aria-label={t.nav.brandAria}>
      <BrandMark />
      <span>VibeCoding</span>
    </a>
    <div class="nav-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
    <div class="nav-actions">
      <LangSwitch />
      <a class="nav-cta" href="#contact">{t.nav.cta}</a>
    </div>
  </nav>
</header>
