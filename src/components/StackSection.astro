---
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
import MagicCard from './MagicCard.astro';
import { ui } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].stack;

// Icon + color metadata stays fixed; only the label text is localized (from t.groups).
const iconMeta = [
  [
    ['cube', 'violet'],
    ['monitor', 'violet'],
    ['bulb', 'blue'],
    ['sparkle', 'blue'],
  ],
  [
    ['node', 'green'],
    ['bolt', 'green'],
    ['bolt', 'cyan'],
    ['cloud', 'white'],
  ],
  [
    ['triangle', 'orange'],
    ['html', 'orange'],
    ['waves', 'cyan'],
    ['diamond', 'rose'],
  ],
  [
    ['code', 'white'],
    ['automation', 'white'],
    ['webhook', 'white'],
    ['target', 'blue'],
  ],
  [
    ['database', 'white'],
    ['database', 'white'],
    ['database', 'white'],
  ],
  [
    ['triangle', 'white'],
    ['github', 'white'],
    ['branch', 'white'],
  ],
];

const groups = t.groups.map((group, i) => ({
  title: group.title,
  items: group.items.map((label, j) => [iconMeta[i][j][0], iconMeta[i][j][1], label]),
}));
---

<section class="section" id="stack">
  <SectionHeading
    titleStart={t.titleStart}
    titleAccent={t.titleAccent}
    text={t.text}
  />
  <div class="tool-grid">
    {groups.map((group) => (
      <MagicCard class="glass-card">
        <div class="card-inner">
          <h3>{group.title}</h3>
          <ul class="list">
            {group.items.map(([icon, color, label]) => (
              <li><span class:list={['mini-icon', color]}><Icon name={icon} class="" /></span>{label}</li>
            ))}
          </ul>
        </div>
      </MagicCard>
    ))}
  </div>
</section>

<style>
  .card-inner {
    padding: 26px 28px;
    height: 100%;
  }
  .glass-card {
    /* Override existing styles if necessary, but MagicCard handles the background and border */
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }
</style>
