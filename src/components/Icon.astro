---
import { Icon as AstroIcon } from 'astro-icon/components';

interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'icon' } = Astro.props;

/**
 * Local icons for quick access or custom brands.
 * If the name is not found here, it will try to load from Iconify (simple-icons, lucide, etc.)
 */
const localIcons: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="8"/><path d="M12 7v5l3 2"/>',
  chip: '<path d="M8 8h8v8H8z"/><path d="M4 10h4M4 14h4M16 10h4M16 14h4M10 4v4M14 4v4M10 16v4M14 16v4"/>',
  sliders: '<path d="M6 5v14M12 5v14M18 5v14"/><path d="M4 9h4M10 15h4M16 11h4"/>',
  shield: '<path d="M12 3 20 7v6c0 5-3.5 7.5-8 8-4.5-.5-8-3-8-8V7z"/><path d="m9 12 2 2 4-5"/>',
  cube: '<path d="m12 3 8 6v9l-8 3-8-3V9z"/><path d="M12 3v18M4 9l8 4 8-4"/>',
  monitor: '<path d="M4 5h16v10H4z"/><path d="m7 19 3-4h4l3 4"/>',
  bulb: '<path d="M9 18h6M10 22h4"/><path d="M8 14a6 6 0 1 1 8 0c-1 1-1 2-1 3H9c0-1 0-2-1-3z"/>',
  sparkle: '<path d="M12 3v18M3 12h18"/><path d="m7 7 10 10M17 7 7 17"/>',
  node: '<path d="m12 3 8 4v10l-8 4-8-4V7z"/><path d="M9 12h6M12 9v6"/>',
  bolt: '<path d="m13 2-8 12h7l-1 8 8-12h-7z"/>',
  cloud: '<path d="M6 18h12a4 4 0 0 0 0-8 6 6 0 0 0-11-2 5 5 0 0 0-1 10z"/>',
  html: '<path d="M5 3h14l-1 16-6 2-6-2z"/><path d="M8 8h8M8 12h7l-.5 4-2.5 1-2.5-1"/>',
  css: '<path d="M5 3h14l-1 16-6 2-6-2z"/><path d="M8 8h8l-.5 4H9l.5 4 2.5 1 2.5-1 .3-2"/>',
  js: '<path d="M5 5h14v14H5z"/><path d="M9 15c0 2 3 2 3 0V9M15 15c1 2 4 1 4-1 0-2-4-1-4-3 0-2 3-2 4-1"/>',
  waves: '<path d="M3 12c3-5 6-5 9 0 3 5 6 5 9 0"/><path d="M3 17c3-5 6-5 9 0 3 5 6 5 9 0"/>',
  database: '<ellipse cx="12" cy="6" rx="7" ry="3"/><path d="M5 6v6c0 2 14 2 14 0V6"/><path d="M5 12v6c0 2 14 2 14 0v-6"/>',
  code: '<path d="M8 17 4 13l4-4M16 7l4 4-4 4M14 4l-4 16"/>',
  webhook: '<circle cx="7" cy="7" r="3"/><circle cx="17" cy="17" r="3"/><path d="M10 8c4 1 5 2 6 6"/>',
  automation: '<path d="M4 14h6l2-7 2 10 2-5h4"/><path d="M5 19 19 5"/>',
  triangle: '<path d="m12 3 9 18H3z"/>',
  github: '<path d="M9 19c-5 1-5-3-7-4M15 22v-4c0-1 .3-1.8 1-2.5 3-.3 6-1.5 6-7A5.5 5.5 0 0 0 20 4c.2-1.5-.2-2.5-.8-3 0 0-1.4 0-3 1.2A10 10 0 0 0 12 2a10 10 0 0 0-4.2.2C6.2 1 4.8 1 4.8 1 4.2 1.5 3.8 2.5 4 4a5.5 5.5 0 0 0-2 4.5c0 5.5 3 6.7 6 7 .7.7 1 1.5 1 2.5v4"/>',
  branch: '<circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="12" cy="18" r="3"/><path d="M8.5 7.5 11 15M15.5 7.5 13 15"/>',
  check: '<circle cx="12" cy="12" r="8"/><path d="m9 12 2 2 4-5"/>',
  diamond: '<path d="m12 3 6 9-6 9-6-9z"/><path d="M9 12h6"/>',
  layers: '<path d="m12 3 8 6-8 6-8-6z"/><path d="m4 15 8 6 8-6"/><path d="m8 12 4 3 4-3"/>',
  circleSplit: '<path d="M12 3a9 9 0 1 0 0 18"/><path d="M12 3a9 9 0 1 1 0 18"/>',
  target: '<path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9l7-4"/>',
  box: '<path d="M12 3v18M5 8l7-5 7 5M5 16l7 5 7-5"/><path d="m5 8 7 5 7-5M5 16l7-5 7 5"/>',
};

const isLocal = name in localIcons;
---

{
  isLocal ? (
    <svg class={className} viewBox="0 0 24 24" set:html={localIcons[name]} />
  ) : (
    <AstroIcon name={name} class={className} />
  )
}
