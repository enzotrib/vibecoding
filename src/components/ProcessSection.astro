---
import SectionHeading from './SectionHeading.astro';
import MagicCard from './MagicCard.astro';

const cards = [
  {
    title: '⚡ Speed first',
    text: 'MVPs in days, not months. Rapid iteration is the core of my workflow.',
    icon: 'bolt',
    color: 'orange',
  },
  {
    title: '🧠 AI-native development',
    text: 'I leverage AI tools to accelerate development, reduce friction, and explore more solutions faster.',
    icon: 'brain',
    color: 'violet',
  },
  {
    title: '🔁 Iterative approach',
    text: 'Build → test → improve. Continuous delivery mindset.',
    icon: 'refresh',
    color: 'blue',
  },
];
---

<section class="section process" id="process">
  <SectionHeading
    titleStart="How I"
    titleAccent="build"
    text="My process is simple: move fast, build smart, iterate constantly."
  />
  <div class="process-grid">
    {cards.map((card) => (
      <MagicCard class="process-card-magic">
        <div class="process-card-inner">
          <div class:list={['process-mark', card.color]}>
            {card.icon === 'bolt' && <svg viewBox="0 0 24 24"><path d="m13 2-8 12h7l-1 8 8-12h-7z" fill="currentColor" stroke="none"></path></svg>}
            {card.icon === 'brain' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.54Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.54Z"/></svg>}
            {card.icon === 'refresh' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>}
          </div>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </div>
      </MagicCard>
    ))}
  </div>
</section>

<style>
  .process-card-inner {
    padding: 38px 32px 34px;
    height: 100%;
  }
  .process-card-magic {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }
</style>
