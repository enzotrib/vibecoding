---
import Icon from "./Icon.astro";
import SectionHeading from "./SectionHeading.astro";
import MagicCard from "./MagicCard.astro";
import orbyImage from "../assets/orby.webp";
import picstreamsImage from "../assets/picstreams.webp";
import translateImage from "../assets/traslate-app.webp";
import arranzImage from "../assets/arranz-guitars.webp";
import { ui } from "../i18n/ui";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = ui[lang].builds;

// Images, URLs, badge color-coding, and meta icons stay fixed; only text is localized.
const buildMeta = [
  { image: orbyImage, url: "https://orby-dpgm.onrender.com/", badgeType: "concept", metaIcons: [["clock", ""], ["check", "green"]] },
  { image: picstreamsImage, url: "https://picstreams.com/", badgeType: "live", metaIcons: [["sparkle", "violet"], ["diamond", "blue"]] },
  { image: translateImage, url: "#", badgeType: "concept", metaIcons: [["sparkle", "violet"], ["clock", ""]] },
  { image: arranzImage, url: "https://arranz-guitars.vercel.app/", badgeType: "in-progress", metaIcons: [["sparkle", "violet"], ["check", "green"]] },
];

const builds = t.items.map((item, i) => ({
  title: item.title,
  description: item.description,
  image: buildMeta[i].image,
  url: buildMeta[i].url,
  badge: { text: item.badge, type: buildMeta[i].badgeType },
  tags: item.tags,
  meta: item.meta.map((label, j) => [buildMeta[i].metaIcons[j][0], buildMeta[i].metaIcons[j][1], label]),
}));
---

<section class="section builds" id="builds">
  <SectionHeading
    titleStart={t.titleStart}
    titleAccent={t.titleAccent}
    text={t.text}
  />
  <div class="build-grid">
    {
      builds.map((build) => (
        <MagicCard class="build-card-magic">
          <a
            href={build.url || "#"}
            target="_blank"
            rel="noopener noreferrer"
            class="build-card-inner"
          >
            <div class="build-visual">
              <div class="img-container">
                <img
                  src={build.image.src}
                  alt={build.title}
                  class="build-img"
                />
                {build.badge && (
                  <span class:list={["badge", build.badge.type]}>
                    {(build.badge.type === "live" ||
                      build.badge.type === "in-progress") && (
                      <span class="dot" />
                    )}
                    {build.badge.text}
                  </span>
                )}
              </div>
            </div>
            <div class="build-body">
              <h3>{build.title}</h3>
              <p>{build.description}</p>
              <div class="tags">
                {build.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <div class="build-meta">
              {build.meta.map(([icon, color, label]) => (
                <span class="meta-item">
                  <Icon name={icon} class={`icon ${color}`} />
                  {label}
                </span>
              ))}
            </div>
          </a>
        </MagicCard>
      ))
    }
  </div>
</section>

<style>
  /* Base Styles (Desktop) */
  .build-card-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 20px;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .build-card-magic {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
  }
  .build-visual {
    padding: 24px 0 24px 24px;
  }
  .img-container {
    position: relative;
    width: 100%;
    height: 140px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
  }
  .build-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .build-card-inner:hover .build-img {
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(4px);
  }

  .badge.concept {
    background: rgba(141, 92, 255, 0.25);
    color: #b592ff;
    border: 1px solid rgba(141, 92, 255, 0.3);
  }

  .badge.live {
    background: rgba(59, 213, 132, 0.25);
    color: #3bd584;
    border: 1px solid rgba(59, 213, 132, 0.3);
  }

  .badge.in-progress {
    background: rgba(255, 138, 91, 0.25);
    color: #ff8a5b;
    border: 1px solid rgba(255, 138, 91, 0.3);
  }

  .dot {
    width: 6px;
    height: 6px;
    background: currentColor;
    border-radius: 50%;
    box-shadow: 0 0 10px currentColor;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
    100% {
      opacity: 1;
    }
  }

  .build-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 26px;
  }

  /* Responsive Styles (Mobile) */
  @media (max-width: 1120px) {
    .build-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .build-card-inner {
      grid-template-columns: 1fr;
    }
    .build-visual {
      padding: 24px !important; /* Forces symmetrical padding on mobile */
    }
    .img-container {
      height: 220px !important; /* Forces 220px height on mobile */
    }
    .build-body {
      padding: 24px !important;
    }
    .build-meta {
      padding: 18px 24px !important;
    }
  }
</style>
